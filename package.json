{
  "name": "css-dice-roller",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/gnuton/css-dice-roller"
  },
  "description": "A high-performance, 3D polyhedral dice roller built with CSS transforms.",
  "author": "Antonio Aloisio",
  "license": "MIT",
  "main": "./dist/css-dice-roller.umd.cjs",
  "module": "./dist/css-dice-roller.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/css-dice-roller.js",
      "require": "./dist/css-dice-roller.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "sass": "^1.98.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
